<mxfile host="app.diagrams.net" agent="Claude" version="21.0.0">
  <diagram name="cascade" id="cascade">
    <mxGraphModel dx="1100" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="470" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Cost-aware cascade — spend on the expensive tier only when the cheap one falls short" style="text;html=1;fontSize=17;fontStyle=1;align=left;verticalAlign=middle;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="30" y="20" width="1120" height="28" as="geometry" />
        </mxCell>

        <mxCell id="in" value="stage input&#10;(document)" style="shape=document;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="110" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cheap" value="CHEAP tier&#10;passthrough / small model&#10;(low cost)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="150" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="score" value="score ≥ threshold ?&#10;(configurable)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="140" width="180" height="100" as="geometry" />
        </mxCell>
        <mxCell id="keep" value="use cheap result&#10;tier = primary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="90" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="strong" value="STRONG tier (fallback)&#10;Docling OCR / VLM / large model&#10;(higher cost)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="220" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="out" value="stage output&#10;tier + score recorded&#10;(cost visibility)" style="shape=document;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="980" y="150" width="150" height="90" as="geometry" />
        </mxCell>

        <mxCell id="ce1" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#333333;" edge="1" parent="1" source="in" target="cheap"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce2" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#333333;" edge="1" parent="1" source="cheap" target="score"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce3" value="yes" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#2d7a2d;fontColor=#2d7a2d;fontSize=11;" edge="1" parent="1" source="score" target="keep"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce4" value="no → escalate" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#b85450;fontColor=#b85450;fontSize=11;" edge="1" parent="1" source="score" target="strong"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce5" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#333333;" edge="1" parent="1" source="keep" target="out"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce6" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#333333;" edge="1" parent="1" source="strong" target="out"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="ex" value="Real example (offline): text PDF → cheap passthrough is enough (primary).  Scanned receipt → escalate to Docling OCR (fallback)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;align=left;verticalAlign=middle;spacingLeft=8;fontStyle=2;" vertex="1" parent="1">
